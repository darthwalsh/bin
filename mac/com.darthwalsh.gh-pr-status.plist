<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.darthwalsh.gh-pr-status</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/mise</string>
        <string>exec</string>
        <string>--</string>
        <string>/Users/walshca/code/bin/gh-pr-status.py</string>
    </array>

    <!-- <key>EnvironmentVariables</key>
    <dict>
        <key>GH_HOST</key>
        <string>git.example.com</string>
    </dict> -->

    <!-- Poll every 5 minutes -->
    <key>StartInterval</key>
    <integer>300</integer>

    <!-- Run once at load time too -->
    <key>RunAtLoad</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/Users/walshca/adsk</string>

    <key>StandardOutPath</key>
    <string>/tmp/gh-pr-status.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/gh-pr-status.log</string>
</dict>
</plist>
